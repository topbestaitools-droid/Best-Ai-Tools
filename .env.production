# Production Environment Variables
# IMPORTANT: Never commit sensitive values. Use Vercel Secrets instead.

# Database
DATABASE_URL="postgresql://user:password@db-prod.example.com:5432/aiadvisor"

# NextAuth
NEXTAUTH_URL="https://aiadvisor.tools"
NEXTAUTH_SECRET="your-production-secret-key-change-this"

# OAuth Providers (GitHub)
GITHUB_ID="your-production-github-id"
GITHUB_SECRET="your-production-github-secret"

# Email (Resend)
RESEND_API_KEY="re_your_production_resend_key"
EMAIL_FROM="noreply@aiadvisor.tools"

# OpenAI (for embeddings)
OPENAI_API_KEY="sk_prod_your_production_key"

# Analytics
NEXT_PUBLIC_GA_ID="G-PRODUCTION_ID"

# API
NEXT_PUBLIC_API_URL="https://aiadvisor.tools"
API_SECRET="your-production-api-secret"

# Environment
NODE_ENV="production"
NEXT_PUBLIC_ENV="production"

# Feature Flags
NEXT_PUBLIC_ENABLE_PWA="true"
NEXT_PUBLIC_ENABLE_ANALYTICS="true"
NEXT_PUBLIC_ENABLE_BETA_FEATURES="false"

# Slack (for notifications)
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/YOUR/WEBHOOK/URL"
